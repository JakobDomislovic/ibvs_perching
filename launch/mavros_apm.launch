<launch>
  <!-- mavros bringup for ArduPilot FCUs (real world).

       Self-contained merge of uav_ros_general's apm2.launch +
       mavros_node.launch so ibvs_perching only depends on mavros itself
       (system package), not on the uav_ros_stack. The plugin config is the
       package-local config/apm_config.yaml; the pluginlists come straight
       from the mavros package. -->

  <arg name="fcu_url" default="/dev/ttyUSB_px4:921600"/>
  <arg name="gcs_url" default=""/>
  <arg name="tgt_system" default="1"/>
  <arg name="tgt_component" default="1"/>
  <arg name="log_output" default="screen"/>
  <arg name="fcu_protocol" default="v2.0"/>
  <arg name="respawn_mavros" default="false"/>
  <arg name="namespace" default="$(env UAV_NAMESPACE)"/>

  <arg name="pluginlists_yaml" default="$(find mavros)/launch/apm_pluginlists.yaml"/>
  <arg name="config_yaml" default="$(find ibvs_perching)/config/apm_config.yaml"/>

  <group ns="$(arg namespace)">
    <node pkg="mavros" type="mavros_node" name="mavros"
          required="$(eval not respawn_mavros)" clear_params="true"
          output="$(arg log_output)" respawn="$(arg respawn_mavros)">
      <param name="fcu_url" value="$(arg fcu_url)"/>
      <param name="gcs_url" value="$(arg gcs_url)"/>
      <param name="target_system_id" value="$(arg tgt_system)"/>
      <param name="target_component_id" value="$(arg tgt_component)"/>
      <param name="fcu_protocol" value="$(arg fcu_protocol)"/>
      <param name="imu/frame_id" value="$(arg namespace)/imu_link"/>

      <!-- load blacklist, config -->
      <rosparam command="load" file="$(arg pluginlists_yaml)"/>
      <rosparam command="load" file="$(arg config_yaml)"/>
      <remap from="diagnostics" to="mavros_diagnostics"/>
    </node>
  </group>

</launch>
